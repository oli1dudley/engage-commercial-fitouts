# Destination mailbox for project enquiry form submissions.
# TODO(launch): set the confirmed address in the deployment environment.
# The form endpoint should read this value — never hard-code the address.
CONTACT_FORM_DESTINATION=

# Public URL of the enquiry-form submission endpoint. While unset, the form
# shows a controlled "submission unavailable" state instead of a simulated
# success, and entered details are kept on the page.
# TODO(launch): point at the live form handler once it exists.
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# Pre-launch indexing lock. The site only becomes indexable when this is
# EXACTLY "true"; any other state (missing, empty, false, misspelled) keeps
# every page noindex/nofollow, robots.txt at "Disallow: /" and emits an
# X-Robots-Tag blocking header.
# TODO(launch): Set to true only after the final domain, legal information,
# contact details, live form and launch approval are complete.
SITE_INDEXING_ENABLED=false
